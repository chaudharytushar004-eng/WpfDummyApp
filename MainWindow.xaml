<Window x:Class="WpfDummyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dummy App" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE MENU -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>
                <!-- App title / logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,25,0,30">
                    <TextBlock Text="ARISTA" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Dummy Panel" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                </StackPanel>

                <!-- Menu items -->
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnHome" Content="🏠  Home" Style="{StaticResource MenuButtonStyle}" Click="Menu_Click"/>
                    <Button x:Name="BtnSecurity" Content="🛡️  Security" Style="{StaticResource MenuButtonStyle}" Click="Menu_Click"/>
                    <Button x:Name="BtnAccount" Content="👤  Account" Style="{StaticResource MenuButtonStyle}" Click="Menu_Click"/>
                    <Button x:Name="BtnSettings" Content="⚙️  Settings" Style="{StaticResource MenuButtonStyle}" Click="Menu_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- RIGHT SIDE CONTENT AREA -->
        <Border Grid.Column="1" Background="{StaticResource ContentBg}">
            <ContentControl x:Name="MainContent"/>
        </Border>
    </Grid>
</Window>

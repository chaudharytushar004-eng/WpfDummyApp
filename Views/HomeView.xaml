<UserControl x:Class="WpfDummyApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page heading -->
        <TextBlock Grid.Row="0" Text="Home" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- 4 boxes x 2 rows = 8 boxes total -->
        <UniformGrid Grid.Row="1" Rows="2" Columns="4">

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="📦" FontSize="26"/>
                    <TextBlock Text="Box 1" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="📊" FontSize="26"/>
                    <TextBlock Text="Box 2" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="🛡️" FontSize="26"/>
                    <TextBlock Text="Box 3" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="⚡" FontSize="26"/>
                    <TextBlock Text="Box 4" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="🔔" FontSize="26"/>
                    <TextBlock Text="Box 5" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="📁" FontSize="26"/>
                    <TextBlock Text="Box 6" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="👥" FontSize="26"/>
                    <TextBlock Text="Box 7" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardBoxStyle}">
                <StackPanel>
                    <TextBlock Text="⚙️" FontSize="26"/>
                    <TextBlock Text="Box 8" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Sample info" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</UserControl>
